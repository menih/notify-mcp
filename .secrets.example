# Copy this file to ~/.notify-mcp-secrets and fill in your tokens.
# release.sh sources this file automatically — no env vars to remember.
#
# chmod 600 ~/.notify-mcp-secrets   (so other users on the box can't read it)

# npm — generate at https://www.npmjs.com/settings/<your-username>/tokens
# Use a Granular token with "Bypass 2FA" enabled, scoped to omni-notify-mcp.
NPM_TOKEN=npm_paste_your_npm_token_here

# VS Code Marketplace — generate at https://dev.azure.com/_usersSettings/tokens
# Scope: Custom defined → Marketplace → Manage. Org: All accessible orgs.
VSCE_PAT=paste_your_vsce_pat_here
